# BTC Gift Card Frontend - Environment Variables Template
# Copy this file to .env and fill in your values

# For development without Docker (direct Vite dev server)
VITE_BTC_GIFTCARD_API_URL_ENV=http://localhost:3202

# For development with Docker (app container only, no nginx)
# docker-compose up -d --build app
# VITE_BTC_GIFTCARD_API_URL_ENV=http://localhost:3202

# For development with Docker + nginx
# docker-compose up -d --build
# VITE_BTC_GIFTCARD_API_URL_ENV=https://api.gifter.local
